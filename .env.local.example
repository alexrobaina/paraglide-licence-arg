# Supabase — get these from your project: Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# SERVER-ONLY. Never expose to the browser or paste in chat. (API Keys → secret key)
SUPABASE_SECRET_KEY=sb_secret_xxx

# Resend — email sending (added in P3). https://resend.com → API Keys
RESEND_API_KEY=your-resend-api-key
# The "from" address must be a domain you verified in Resend
EMAIL_FROM=Paraglide Exam <noreply@yourdomain.com>

# Base URL used to build invitation links (magic links, /exam/[token])
NEXT_PUBLIC_SITE_URL=http://localhost:3000
